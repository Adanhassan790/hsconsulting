# Django Settings
DEBUG=False
DJANGO_SECRET_KEY=your-secret-key-generate-a-strong-one-for-production
ALLOWED_HOSTS=your-railway-domain.railway.app,localhost,127.0.0.1

# Database - For Railway, use DATABASE_URL (auto-provided by Railway)
# Railway PostgreSQL will automatically provide this via environment variable
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis/Celery (optional)
CELERY_BROKER_URL=redis://your_redis_host:6379/0
CELERY_RESULT_BACKEND=redis://your_redis_host:6379/0

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=noreply@hsconsulting.co.ke
OWNER_EMAIL=owner@hsconsulting.co.ke

# Twilio (SMS) - Optional
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://yourdomain.railway.app

# Site Information
ADMIN_PASSWORD=YourVeryStrongPasswordHere
SITE_NAME=HS Consulting
